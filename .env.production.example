# =============================================================================
# Variables d'environnement pour la production
# À configurer dans Dokploy UI (Environment tab)
# =============================================================================

# Application
NODE_ENV=production
# Générer avec: node ace generate:key (une seule fois, lors de l'installation initiale)
APP_KEY=

# =============================================================================
# Base de données
# Utiliser le nom du service PostgreSQL Dokploy comme DB_HOST
# =============================================================================
DB_HOST=<nom-service-postgres-dokploy>
DB_PORT=5432
DB_USER=<user>
DB_PASSWORD=<password>
DB_DATABASE=tournament_registration

# =============================================================================
# URLs publiques
# =============================================================================
VITE_API_URL=https://api.votredomaine.com
FRONTEND_URL=https://app.votredomaine.com

# =============================================================================
# Cookies (obligatoire pour HTTPS avec domaines séparés)
# =============================================================================
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
# COOKIE_DOMAIN=.votredomaine.com

# =============================================================================
# SMTP - Configuration mail production
# =============================================================================
SMTP_HOST=smtp.votreserveur.com
SMTP_PORT=465
SMTP_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=

# =============================================================================
# HelloAsso - Paiement en ligne
# =============================================================================
HELLOASSO_CLIENT_ID=
HELLOASSO_CLIENT_SECRET=
HELLOASSO_ORGANIZATION_SLUG=
# Mettre à false pour la production
HELLOASSO_SANDBOX=false

# =============================================================================
# FFTT - Fédération Française de Tennis de Table
# =============================================================================
FFTT_APP_ID=
FFTT_PASSWORD=
# Mettre à false pour la production
FFTT_MOCK=false

# =============================================================================
# Administrateur initial
# =============================================================================
ADMIN_EMAIL=admin@votredomaine.com
ADMIN_PASSWORD=<mot-de-passe-securise>
ADMIN_NAME=Administrateur

# =============================================================================
# Configuration paiements
# =============================================================================
PAYMENT_EXPIRATION_MINUTES=30
PAYMENT_CLEANUP_INTERVAL_MINUTES=5

# =============================================================================
# Contact
# =============================================================================
# Email de contact affiché dans le layout public
VITE_CONTACT_EMAIL=contact@votredomaine.com
