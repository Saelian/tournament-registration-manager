# .env.example

# =============================================================================
# Database initialization (used by Docker Compose)
# =============================================================================
POSTGRES_USER=adonis_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=tournament-registration-manager
POSTGRES_PORT=5432

# =============================================================================
# Backend (AdonisJS) configuration
# =============================================================================
TZ=UTC
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info
# Generate this key using `node ace generate:key`
APP_KEY=
NODE_ENV=development

# Database connection for AdonisJS
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=adonis_user
DB_PASSWORD=your_secure_password
DB_DATABASE=tournament-registration-manager

SESSION_DRIVER=cookie

# Cookie configuration (for cross-origin HTTPS, set both values)
# Usefull if frontend and backend are served from different domains over HTTPS
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=none
# COOKIE_DOMAIN=.your-domain.com

# =============================================================================
# Mail Configuration
# =============================================================================
# For Dev/Test, use mailpit
SMTP_HOST=localhost
SMTP_PORT=1025

# For production usage
# SMTP_HOST=smtp.your-domain.com
# SMTP_PORT=465
# SMTP_TLS=true
# SMTP_USERNAME=postmaster@your-domain.com
# SMTP_PASSWORD=secret

# =============================================================================
# FFTT API Client
# =============================================================================
FFTT_APP_ID=
FFTT_PASSWORD=

# If true, will use mock data instead of real FFTT API
# Mock data is located in packages/fftt-client/data/mock-players.json
FFTT_MOCK=false

# =============================================================================
# HelloAsso Payment Integration
# =============================================================================
HELLOASSO_CLIENT_ID=
HELLOASSO_CLIENT_SECRET=

# Slug can be found in the URL of your HelloAsso organization page
HELLOASSO_ORGANIZATION_SLUG=

# If true, will use HelloAsso sandbox environment
HELLOASSO_SANDBOX=true

# =============================================================================
# Application configuration
# =============================================================================

# Admin credentials
# Initialize administrator credentials on first run
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin
ADMIN_NAME=Admin

# Payment Expiration
# If a payment is not completed within this time (in minutes), it will be cancelled
PAYMENT_EXPIRATION_MINUTES=30
# Interval (in minutes) to clean up expired payments, runned by node-cron
PAYMENT_CLEANUP_INTERVAL_MINUTES=5

# =============================================================================
# Frontend (Vite) configuration
# =============================================================================
VITE_API_URL=http://localhost:3333
VITE_ALLOWED_HOST=localhost
# Used by the API to generate return URLs after payment
FRONTEND_URL=http://localhost:5173

# Contact email displayed in the public layout
VITE_CONTACT_EMAIL=contact@example.com
